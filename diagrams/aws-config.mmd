  subgraph DNS["🌐 Route 53 — brignano.io"]
    Zone["aws_route53_zone.default\nbrignano.io\nZ03854061GJ89FG9XI2HY"]
    WebRecord["aws_route53_record.root\nbrignano.io → Vercel"]
    MailRecord["aws_route53_record.mx\nMX → SES inbound"]
    Zone --> WebRecord
    Zone --> MailRecord
  end

  subgraph Email["📧 SES — Receipt Rules"]
    RuleSet["aws_ses_receipt_rule_set.default\ndefault-rule-set"]
    RuleForward["aws_ses_receipt_rule.forward"]
    RuleNoreply["aws_ses_receipt_rule.noreply"]
    RuleArchive["aws_ses_receipt_rule.archive"]
    RuleSet --> RuleForward & RuleNoreply & RuleArchive
  end

  subgraph Storage["🪣 S3"]
    Bucket["aws_s3_bucket.emails\nbrignano.io-emails"]
  end

  subgraph Compute["⚡ Lambda"]
    Fn["aws_lambda_function.email_forwarder\nemail-forwarder"]
    Logs["aws_cloudwatch_log_group\n/aws/lambda/email-forwarder"]
    Fn --> Logs
  end

  subgraph Perms["🔐 IAM"]
    Role["aws_iam_role.lambda"]
    Policy["aws_iam_role_policy.lambda\nS3 read · SES send"]
    Role --> Policy
  end

  Vercel["Vercel"]:::external
  Gmail["Gmail"]:::external

  MailRecord -->|inbound mail| RuleSet
  WebRecord -->|web traffic| Vercel
  RuleArchive -->|store raw email| Bucket
  RuleForward -->|trigger| Fn
  Bucket -->|read body| Fn
  Fn -->|forward| Gmail
  Role -.->|assumed by| Fn

  class Zone,WebRecord,MailRecord route53
  class RuleSet,RuleForward,RuleNoreply,RuleArchive,Logs ses
  class Bucket s3
  class Fn lambda
  class Role,Policy iam
